# SC// Sizer environment configuration
# Copy this file to .env and fill in the values

# Database connection (defaults to local Docker PostgreSQL if not set)
# DATABASE_URL=postgresql://sizer:sizer@db:5432/sizer

# Session signing key — REQUIRED in production. Must be a long random string and
# the SAME value across all gunicorn workers (set it here, not per-worker). If
# unset, an ephemeral key is generated and logins won't survive restarts.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Set to "true" when serving over HTTPS so the session cookie is marked Secure.
# SESSION_COOKIE_SECURE=false

# Bootstrap super admin (created on boot if absent; never overwrites an existing
# account's password). The super admin is the only role that can edit models and
# manage tenants/users. Exempt from the public-email-domain ban.
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=

# Daily maintenance scheduler — runs the retention purge + GDPR PII
# anonymization once per calendar day (coordinated across workers). Leave the
# defaults unless you have a reason to change them.
# ENABLE_SCHEDULER=1                 # set to 0 to disable the in-app scheduler
# MAINTENANCE_INTERVAL_SECONDS=3600  # how often the loop re-checks (day-gated)
