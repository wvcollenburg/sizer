# SC// Sizer environment configuration
# Copy this file to .env and fill in the values

# Database connection (defaults to local Docker PostgreSQL if not set)
# DATABASE_URL=postgresql://sizer:sizer@db:5432/sizer

# Session signing key — REQUIRED in production. Must be a long random string and
# the SAME value across all gunicorn workers (set it here, not per-worker). If
# unset, an ephemeral key is generated and logins won't survive restarts.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Set to "true" when serving over HTTPS so the session cookie is marked Secure.
# In production (behind the nginx TLS proxy) this SHOULD be true so the app is
# the single source of the cookie's Secure/HttpOnly/SameSite flags — then drop
# any proxy_cookie_flags from nginx to avoid duplicated cookie attributes.
# SESSION_COOKIE_SECURE=false

# Public base URL used to build links in outbound emails (verification, password
# reset). Set this in production so links can't be poisoned via a spoofed Host
# header on the request that triggers the email. Falls back to the request URL
# when unset (fine for local/dev).
# APP_BASE_URL=https://betasizer.demolabs.me

# Max accepted request body in bytes (default 32 MiB) — caps upload size to
# blunt memory-exhaustion uploads. Raise if legitimate RVTools/Live Optics
# exports are larger.
# MAX_CONTENT_LENGTH_BYTES=33554432

# Rate-limit storage backend for flask-limiter. Defaults to in-memory, which is
# per-gunicorn-worker (a limit bites after roughly workers×limit). Point at a
# shared store for exact, cross-worker limits, e.g. redis://redis:6379.
# RATELIMIT_STORAGE_URI=memory://

# Bootstrap super admin (created on boot if absent; never overwrites an existing
# account's password). The super admin is the only role that can edit models and
# manage tenants/users. Exempt from the public-email-domain ban.
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=

# Daily maintenance scheduler — runs the retention purge + GDPR PII
# anonymization once per calendar day (coordinated across workers). Leave the
# defaults unless you have a reason to change them.
# ENABLE_SCHEDULER=1                 # set to 0 to disable the in-app scheduler
# MAINTENANCE_INTERVAL_SECONDS=3600  # how often the loop re-checks (day-gated)
